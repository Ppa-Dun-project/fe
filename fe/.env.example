# Browser API base URL.
# - Keep empty in local dev when using Vite proxy.
# - Set to full backend URL in environments without proxy.
VITE_API_BASE_URL=

# Dev-only: Vite proxy target for "/api".
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# App runtime defaults
VITE_DRAFT_ROOM_ID=default
VITE_MY_TEAM_ID=team-me
